{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PaintCam",
  "version": "0.1.0",
  "identifier": "com.paintcam.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PaintCam",
        "width": 880,
        "height": 620,
        "minWidth": 420,
        "minHeight": 420
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
